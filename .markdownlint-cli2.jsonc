{
  "config": {
    // =========================================================================
    // Axiarch Markdownlint Configuration
    //
    // 方針: markdownlint 公式 "relaxed" スタイルの設定を個別ルールIDで直接展開し、
    //       Axiarch 固有の追加無効化を加えたもの。
    //
    // relaxed スタイル出典:
    //   https://github.com/DavidAnson/markdownlint/blob/main/style/relaxed.json
    // =========================================================================

    "default": true,

    // =========================================================================
    // relaxed スタイル由来の無効化
    // =========================================================================

    // --- whitespace カテゴリ (個別展開) ---
    // MD009: 末尾スペース
    "MD009": false,
    // MD010: ハードタブ
    "MD010": false,
    // MD012: 複数連続空行
    "MD012": false,
    // MD022: 見出し前後の空行
    "MD022": false,
    // MD027: 引用符後の複数スペース
    "MD027": false,
    // MD028: 引用ブロック内の空行
    "MD028": false,
    // MD030: リストマーカー後のスペース
    "MD030": false,
    // MD031: フェンス付きコードブロック前後の空行
    "MD031": false,
    // MD032: リスト前後の空行
    "MD032": false,

    // --- その他 relaxed 由来 ---
    // MD007: 順序なしリストのインデント
    "MD007": false,
    // MD013: 行長制限 (日本語CJKでは80文字制限が不適合)
    "MD013": false,
    // MD033: インラインHTML (<details>, <summary> 等)
    "MD033": false,
    // MD034: 裸の URL
    "MD034": false,
    // MD040: フェンス付きコードブロックの言語指定
    "MD040": false,
    // MD041: 先頭行の H1 強制
    "MD041": false,

    // =========================================================================
    // Axiarch 固有: バイリンガル文書構造への適応
    // =========================================================================

    // MD024: 同名見出しの許可
    // 理由: JA/EN パリティ構造で同名の見出し（例: "## Overview"）が発生
    "MD024": false,

    // MD025: 複数の H1 見出しを許可
    // 理由: バイリンガル文書で H1 が複数存在する構造パターンがある
    "MD025": false,

    // MD036: 太字の見出し代用を許可
    // 理由: プロンプト文書やルール文書で **太字** を視覚的区切りとして使用
    "MD036": false,

    // =========================================================================
    // Axiarch 固有: テーブル形式の柔軟性確保
    // 理由: 日本語を含むテーブルは CJK 文字幅の影響でアライメントが崩れやすく、
    //       compact スタイルのテーブルで大量の誤検知が発生する
    // =========================================================================
    "MD055": false,
    "MD056": false,
    "MD058": false,
    "MD060": false
  }
}
